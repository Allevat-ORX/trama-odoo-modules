<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        Seed data for the 7 expense categories.
        noupdate=1 so users can edit names/budgets without module update overwriting.
        The post_init_hook also seeds these via create_default_categories(),
        but this XML provides stable xmlids for references.
    -->

    <record id="expense_category_nomina" model="trama.expense.category">
        <field name="name">Nomina</field>
        <field name="code">NOMINA</field>
        <field name="budget_monthly">50000.0</field>
        <field name="sequence">10</field>
        <field name="color">1</field>
        <field name="note">Sueldo CEO y empleados JCF</field>
    </record>

    <record id="expense_category_tecnologia" model="trama.expense.category">
        <field name="name">Tecnologia</field>
        <field name="code">TECNOLOGIA</field>
        <field name="budget_monthly">6900.0</field>
        <field name="sequence">20</field>
        <field name="color">2</field>
        <field name="note">AWS, IA (LiteLLM, Ollama), Google Workspace, GitHub, Vercel</field>
    </record>

    <record id="expense_category_marketing" model="trama.expense.category">
        <field name="name">Marketing</field>
        <field name="code">MARKETING</field>
        <field name="budget_monthly">10000.0</field>
        <field name="sequence">30</field>
        <field name="color">3</field>
        <field name="note">Ads, Contenido Organico, ImpactX, Growth</field>
    </record>

    <record id="expense_category_oficina" model="trama.expense.category">
        <field name="name">Oficina</field>
        <field name="code">OFICINA</field>
        <field name="budget_monthly">5000.0</field>
        <field name="sequence">40</field>
        <field name="color">4</field>
        <field name="note">Servicios, Limpieza, Material de oficina</field>
    </record>

    <record id="expense_category_software" model="trama.expense.category">
        <field name="name">Software y Prospeccion</field>
        <field name="code">SOFTWARE</field>
        <field name="budget_monthly">3000.0</field>
        <field name="sequence">50</field>
        <field name="color">5</field>
        <field name="note">Instantly.ai, Postiz, herramientas SaaS</field>
    </record>

    <record id="expense_category_otros" model="trama.expense.category">
        <field name="name">Otros</field>
        <field name="code">OTROS</field>
        <field name="budget_monthly">4000.0</field>
        <field name="sequence">60</field>
        <field name="color">6</field>
        <field name="note">Incentivos, Imprevistos, gastos no clasificados</field>
    </record>

    <record id="expense_category_comunicaciones" model="trama.expense.category">
        <field name="name">Comunicaciones</field>
        <field name="code">COMUNICACIONES</field>
        <field name="budget_monthly">1200.0</field>
        <field name="sequence">70</field>
        <field name="color">7</field>
        <field name="note">Zadarma, WaSender, SMS, Gamma AI</field>
    </record>
</odoo>
